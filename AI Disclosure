My prompt: now the most critical part I need to compute actual market adjusted alpha for every transaction, the formula is alpha = stock_return - spy_return over a 30 day window starting from the transaction date, download spy once for the entire date range and cache each ticker separately so we dont spam the api, use yfinance dont forget 

AI response: I have implemented an efficient market-adjusted alpha computation engine. The benchmark (SPY ETF as a proxy for the S&P 500) is downloaded once for the full date range, and individual stock histories are cached in a dictionary keyed by ticker — this avoids repeated API calls and reduces runtime significantly on large datasets. The compute_alpha function locates the closest available trading day at or after the transaction date as the entry point, and the closest trading day at or after (transaction date + 30 days) as the exit point, making it robust to weekends and market holidays. Alpha is then the stock's percentage return minus the benchmark's return over the same window — the standard abnormal return definition from the event study literature.

Python
import logging
logging.getLogger('yfinance').setLevel(logging.CRITICAL)

print("--- STEP 2: COMPUTING MARKET-ADJUSTED RETURNS (ALPHA) ---")

ALPHA_WINDOW_DAYS = 30
BENCHMARK_TICKER  = 'SPY'

date_min = df['transaction_date'].min() - timedelta(days=5)
date_max = df['transaction_date'].max() + timedelta(days=ALPHA_WINDOW_DAYS + 15)

benchmark_raw = yf.download(BENCHMARK_TICKER, start=date_min, end=date_max, progress=False)
benchmark_raw.index = benchmark_raw.index.tz_localize(None).normalize()

unique_tickers = df['ticker'].dropna().astype(str).str.strip().unique()
price_cache = {}

for ticker in unique_tickers:
    try:
        data = yf.download(ticker, start=date_min, end=date_max, progress=False)
        if not data.empty:
            data.index = data.index.tz_localize(None).normalize()
            price_cache[ticker] = data
    except Exception:
        pass

print(f"Price data cached: {len(price_cache)} / {len(unique_tickers)} tickers.\n")

def compute_alpha(row, price_cache, benchmark, window=30):
    ticker     = str(row['ticker']).strip()
    trade_date = pd.to_datetime(row['transaction_date'])
    if ticker not in price_cache or benchmark.empty:
        return np.nan
    stock = price_cache[ticker]

    def get_scalar(val):
        if isinstance(val, pd.Series):   return float(val.iloc[0])
        if isinstance(val, pd.DataFrame): return float(val.iloc[0, 0])
        return float(val)

    stock_entry = stock[stock.index >= trade_date]
    bench_entry = benchmark[benchmark.index >= trade_date]
    if stock_entry.empty or bench_entry.empty: return np.nan

    p_s0 = get_scalar(stock_entry['Close'].iloc[0])
    p_b0 = get_scalar(bench_entry['Close'].iloc[0])

    exit_date   = trade_date + timedelta(days=window)
    stock_exit  = stock[stock.index >= exit_date]
    bench_exit  = benchmark[benchmark.index >= exit_date]
    if stock_exit.empty or bench_exit.empty: return np.nan

    r_stock = (get_scalar(stock_exit['Close'].iloc[0]) / p_s0 - 1.0) * 100.0
    r_bench = (get_scalar(bench_exit['Close'].iloc[0]) / p_b0 - 1.0) * 100.0
    return r_stock - r_bench

df['alpha'] = df.apply(compute_alpha, axis=1,
                       price_cache=price_cache,
                       benchmark=benchmark_raw,
                       window=ALPHA_WINDOW_DAYS)

coverage = df['alpha'].notna().sum()
print(f"Alpha coverage : {coverage} / {len(df)} ({100*coverage/len(df):.1f}%)")
print(f"Mean alpha     : {df['alpha'].mean():.3f}%")
print(f"Std alpha      : {df['alpha'].std():.3f}%")


