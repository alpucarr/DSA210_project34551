from itertools import combinations

print("\n--- STEP 14: CO-INVESTMENT NETWORK ANALYSIS (PAGERANK) ---")

co_investments = []
grouped = df.dropna(subset=['ticker', 'transaction_date']).groupby(
    ['transaction_date', 'ticker']
)

for (trade_date, ticker), group in grouped:
    senators_in_group = (
        group[['first_name', 'last_name']].drop_duplicates()
        .apply(lambda r: f"{r['first_name']} {r['last_name']}", axis=1)
        .tolist()
    )
    if len(senators_in_group) > 1:
        for pair in combinations(senators_in_group, 2):
            co_investments.append({'source': pair[0], 'target': pair[1]})

G_sync = nx.Graph()
for edge in co_investments:
    if G_sync.has_edge(edge['source'], edge['target']):
        G_sync[edge['source']][edge['target']]['weight'] += 1
    else:
        G_sync.add_edge(edge['source'], edge['target'], weight=1)

if len(G_sync.nodes) == 0:
    print("No co-investments found.")
else:
    pagerank = nx.pagerank(G_sync, weight='weight')
    top_central_senators = sorted(
        pagerank.items(), key=lambda x: x[1], reverse=True
    )[:10]

    print("\n[Top 10 Central Senators — PageRank]")
    for rank, (senator, score) in enumerate(top_central_senators, 1):
        print(f"{rank}. {senator} (Score: {score:.4f})")

    plt.figure(figsize=(14, 10))
    pos          = nx.spring_layout(G_sync, k=0.6, seed=42)
    node_sizes   = [pagerank[n] * 15000 for n in G_sync.nodes()]
    edge_weights = [G_sync[u][v]['weight'] * 2 for u, v in G_sync.edges()]
    nx.draw_networkx_nodes(G_sync, pos, node_size=node_sizes,
                           node_color='#9370db', alpha=0.85, edgecolors='white')
    nx.draw_networkx_edges(G_sync, pos, width=edge_weights,
                           edge_color='#aaaaaa', alpha=0.6)
    nx.draw_networkx_labels(G_sync, pos, font_size=9, font_weight='bold')
    plt.title("Senate Co-Investment Syndicate Network (PageRank Centrality)",
              fontsize=16, fontweight='bold')
    plt.axis('off')
    plt.tight_layout()
    plt.show()




